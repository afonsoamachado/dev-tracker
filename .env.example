# ========== AZURE DEVOPS CREDENTIALS ==========
# Single organization and PAT for all projects
AZURE_DEVOPS_ORG=your-organization-name
AZURE_DEVOPS_PAT=your-personal-access-token

# ========== PROJECTS CONFIGURATION ==========
# Define multiple projects within the same organization
# Each project only needs NAME and REPOS

AUTHOR=author-name

# PROJECT 1
PROJECT_1_NAME=project1
PROJECT_1_REPOS=repo1,repo2,repo3

# PROJECT 2 (optional)
PROJECT_2_NAME=project2
PROJECT_2_REPOS=repoA,repoB

# PROJECT 3 (optional)
PROJECT_3_NAME=project3
PROJECT_3_REPOS=all  # 'all' to include all repos, or comma-separated list

# ========== OPTIONAL SETTINGS ==========
# Cache timeout in seconds (0 to disable caching)
CACHE_TIMEOUT=300
